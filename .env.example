# Copy this file to ".env" and fill in your own keys.
# At least one provider is required. OpenRouter is the primary provider and
# Gemini is the fallback (the order is defined in src/matcher.py).

# OpenRouter API key — https://openrouter.ai/keys (primary provider)
OPENROUTER_API_KEY=your_openrouter_key_here

# Google Gemini API key — https://aistudio.google.com/app/apikey (fallback)
GEMINI_API_KEY=your_gemini_key_here

# Optional: pin a single OpenRouter model instead of the built-in free list.
# Example: OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_MODEL=
