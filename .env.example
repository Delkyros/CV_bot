# Copy this file to ".env" and fill in your own keys.
# At least one provider is required. OpenRouter is the primary provider and
# Gemini is the fallback (the order is defined in src/matcher.py).
#
# Every value below the API keys is OPTIONAL: each has a sensible default in
# code and is only read from here if you set it. Nothing tunable is hardcoded —
# uncomment and change anything you want to adjust.

# ============================================================================
# API keys (required: at least one)
# ============================================================================

# OpenRouter API key — https://openrouter.ai/keys (primary provider)
OPENROUTER_API_KEY=your_openrouter_key_here

# Google Gemini API key — https://aistudio.google.com/app/apikey (fallback)
GEMINI_API_KEY=your_gemini_key_here

# ============================================================================
# LLM models
# ============================================================================

# Pin a SINGLE OpenRouter model (highest priority; overrides the list below).
# Example: OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_MODEL=

# Override the whole OpenRouter model list (comma-separated, tried in order).
# OPENROUTER_MODELS=openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free

# Gemini model used for the fallback provider.
# GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# LLM call behavior
# ============================================================================

# Sampling temperature for both providers (0.0 = deterministic).
# LLM_TEMPERATURE=0.1

# Max output tokens for OpenRouter responses (room for reasoning + JSON).
# OPENROUTER_MAX_TOKENS=2000

# HTTP timeout (seconds) for OpenRouter requests.
# LLM_REQUEST_TIMEOUT=60

# How many times to walk the full provider chain before giving up.
# LLM_MAX_PROVIDER_CYCLES=3

# Seconds to wait between full-chain retry cycles on quota/limit errors.
# LLM_QUOTA_RETRY_WAIT=60

# ============================================================================
# Contract (CLT) classification
# ============================================================================

# Minimum LLM confidence required to DISCARD a job as non-CLT during collection.
# CONTRACT_DISCARD_CONFIDENCE=0.6

# ============================================================================
# Final report relevance filter (what shows up in the .md)
# ============================================================================

# Minimum CLT confidence (score_clt, 0.0-1.0) for a job to appear. Jobs with a
# non-numeric / "N/A" CLT score are always hidden.
# REPORT_MIN_CLT_SCORE=0.6

# Minimum profile match score (match_score, 0-100) for a job to appear.
# REPORT_MIN_MATCH_SCORE=50

# ============================================================================
# Scraper (LinkedIn collection)
# ============================================================================

# Retries on a 429 / network error per request.
# SCRAPER_MAX_RETRIES=5

# Seconds to wait between retry attempts.
# SCRAPER_RETRY_WAIT=5

# HTTP timeout (seconds) for scraper requests.
# SCRAPER_REQUEST_TIMEOUT=15

# Max search-result pages to walk per term/filter.
# SCRAPER_MAX_PAGES=10

# Friendly random pause between requests (seconds) to avoid 429.
# SCRAPER_MIN_REQUEST_DELAY=1.0
# SCRAPER_MAX_REQUEST_DELAY=3.0

# ============================================================================
# Docker scheduling (read by the container entrypoint, not by main.py)
# ============================================================================

# Seconds between scheduled runs inside Docker. Default 21600 (6h); 0 = run once.
# RUN_INTERVAL_SECONDS=21600

# Run immediately on container start ("true") or wait one interval first ("false").
# RUN_ON_START=true

# Web UI (webapp.py) bind host/port for marking jobs as viewed/applied.
# WEB_HOST=0.0.0.0
# WEB_PORT=8000

# ============================================================================
# File paths
# ============================================================================

# Search/profile configuration file (YAML).
# KEYWORDS_CONFIG_PATH=config/keywords.yaml

# Where the seen-jobs history is persisted (JSON).
# HISTORY_PATH=vagas_historico.json

# Where the filtered report is written (Markdown).
# REPORT_OUTPUT_PATH=vagas_filtradas.md
